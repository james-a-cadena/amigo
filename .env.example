# Database
POSTGRES_USER=amigo
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=amigo

# Valkey (Redis-compatible)
VALKEY_URL=redis://localhost:6379

# Database URL (constructed from above for local dev)
DATABASE_URL=postgres://amigo:change_me_in_production@localhost:5432/amigo

# Authentik OIDC
# Issuer URL format: https://auth.example.com/application/o/<application-slug>/
AUTHENTIK_ISSUER=https://auth.cadenalabs.net/application/o/amigo/
AUTHENTIK_CLIENT_ID=amigo
AUTHENTIK_CLIENT_SECRET=change_me_in_production

# Authentik bootstrap (first run only)
AUTHENTIK_SECRET_KEY=change_me_generate_with_openssl_rand_base64_32
AUTHENTIK_BOOTSTRAP_PASSWORD=change_me_initial_admin_password
AUTHENTIK_BOOTSTRAP_EMAIL=admin@cadenalabs.net
AUTHENTIK_DB_PASSWORD=authentik

# Cloudflare (for Caddy DNS-01 SSL)
CLOUDFLARE_API_TOKEN=change_me_in_production
