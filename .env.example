# =============================================================================
# AMIGO ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your values.
#
# Two deployment modes:
#   1. With bundled Authentik: Run `make up-with-authentik`
#   2. With external OIDC provider: Run `make up` (configure AUTHENTIK_* below)
# =============================================================================

# -----------------------------------------------------------------------------
# Application URLs
# -----------------------------------------------------------------------------
# The public URL where amigo will be accessible
APP_URL=https://amigo.example.com

# Optional: separate URL for dev environment (defaults to APP_URL if not set)
# DEV_APP_URL=https://dev-amigo.example.com

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_USER=amigo
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=amigo

# Database URL (constructed from above, used by Drizzle for local dev/migrations)
DATABASE_URL=postgres://amigo:change_me_in_production@localhost:5432/amigo

# -----------------------------------------------------------------------------
# Cache/Sessions (Valkey/Redis)
# -----------------------------------------------------------------------------
VALKEY_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# OIDC Authentication
# -----------------------------------------------------------------------------
# Works with any OIDC provider: Authentik, Keycloak, Auth0, etc.
#
# For Authentik, create an OAuth2/OpenID Provider application:
#   1. Go to Applications > Providers > Create
#   2. Select "OAuth2/OpenID Provider"
#   3. Set redirect URI to: https://your-amigo-url/api/auth/callback
#   4. Copy the Client ID and Client Secret below
#
# Issuer URL format for Authentik: https://auth.example.com/application/o/<slug>/
AUTHENTIK_ISSUER=https://auth.example.com/application/o/amigo/
AUTHENTIK_CLIENT_ID=amigo
AUTHENTIK_CLIENT_SECRET=change_me_in_production

# -----------------------------------------------------------------------------
# Bundled Authentik (OPTIONAL)
# -----------------------------------------------------------------------------
# Only needed if running Authentik as part of this stack.
# Skip this section if using an external OIDC provider.
#
# To use bundled Authentik: make up-with-authentik

# Secret key for Authentik (generate with: openssl rand -base64 32)
AUTHENTIK_SECRET_KEY=change_me_generate_with_openssl_rand_base64_32

# Initial admin credentials (first run only)
AUTHENTIK_BOOTSTRAP_PASSWORD=change_me_initial_admin_password
AUTHENTIK_BOOTSTRAP_EMAIL=admin@example.com

# Authentik database password
AUTHENTIK_DB_PASSWORD=authentik

# -----------------------------------------------------------------------------
# Reverse Proxy / SSL (Caddy)
# -----------------------------------------------------------------------------
# For DNS-01 SSL certificate challenges via Cloudflare
# Get your API token from: https://dash.cloudflare.com/profile/api-tokens
# Required permissions: Zone:DNS:Edit
CLOUDFLARE_API_TOKEN=change_me_in_production

# -----------------------------------------------------------------------------
# Push Notifications (VAPID)
# -----------------------------------------------------------------------------
# Generate keys with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# -----------------------------------------------------------------------------
# Timezone
# -----------------------------------------------------------------------------
TZ=America/Toronto
