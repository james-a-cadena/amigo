{
  "name": "amigo",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "bash scripts/run-with-1password-environment.sh -- bash scripts/run-vite-with-dev-vars.sh vite dev",
    "dev:setup": "bun run db:migrate:local && bun run db:seed:local",
    "dev:reset": "rm -rf .wrangler/state && bun run dev:setup",
    "build": "react-router build",
    "deploy": "wrangler deploy",
    "db:generate": "cd packages/db && drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply amigo-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply amigo-db --remote",
    "db:seed:local": "wrangler d1 execute amigo-db --local --file=packages/db/seed.sql",
    "db:studio": "cd packages/db && drizzle-kit studio",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@amigo/db": "workspace:*",
    "@clerk/backend": "^1",
    "@clerk/react-router": "^3.0.1",
    "@hono/clerk-auth": "^2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tailwindcss/vite": "^4.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dexie": "^4.3.0",
    "drizzle-orm": "^0.38",
    "hono": "^4.6",
    "hono-react-router-adapter": "^0.6",
    "isbot": "^5.1.35",
    "lucide-react": "^0.577.0",
    "react": "^19",
    "react-dom": "^19",
    "react-router": "^7",
    "recharts": "^2.15.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "vite-plugin-pwa": "^1.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1",
    "@cloudflare/workers-types": "^4",
    "@eslint/js": "^9.39.2",
    "@hono/vite-dev-server": "^0.25.0",
    "@react-router/dev": "^7",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.0.17",
    "drizzle-kit": "^0.30",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.5.0",
    "typescript": "^5.7",
    "typescript-eslint": "^8.50.0",
    "vite": "^6",
    "vite-tsconfig-paths": "^5",
    "vitest": "^4.0.17",
    "wrangler": "^4"
  },
  "packageManager": "bun@1.1.38"
}
