# syntax=docker/dockerfile:1

FROM oven/bun:1.1-alpine

# Install timezone data for TZ environment variable support
RUN apk add --no-cache tzdata

WORKDIR /app

# Copy all workspace files for dependency resolution
COPY package.json bun.lockb* ./
COPY apps/web/package.json ./apps/web/
COPY apps/api/package.json ./apps/api/
COPY packages/db/package.json ./packages/db/
COPY packages/types/package.json ./packages/types/
COPY packages/ui/package.json ./packages/ui/

# Install all dependencies
RUN bun install --frozen-lockfile

# Copy config files needed for TypeScript/build
COPY tsconfig.json turbo.json ./
COPY apps/web/tsconfig.json ./apps/web/
COPY apps/web/next.config.ts ./apps/web/
COPY apps/web/postcss.config.mjs ./apps/web/
COPY apps/web/next-env.d.ts ./apps/web/

# Copy packages (these don't change often, better to have in image)
COPY packages ./packages

# Note: apps/web/src is mounted via volume for hot reload

ENV NEXT_TELEMETRY_DISABLED=1
ENV NODE_ENV=development
ENV WATCHPACK_POLLING=true

WORKDIR /app/apps/web

EXPOSE 3001

# Run without turbopack for better Docker volume compatibility
CMD ["bun", "next", "dev", "--port", "3001"]
