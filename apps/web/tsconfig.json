{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"],
      "@amigo/api": ["../api/src/index.ts"],
      "@amigo/db": ["../../packages/db/src/index.ts"],
      "@amigo/db/*": ["../../packages/db/src/*"],
      "@amigo/types": ["../../packages/types/src/index.ts"],
      "@amigo/ui": ["../../packages/ui/src/index.ts"],
      "@amigo/ui/*": ["../../packages/ui/src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
