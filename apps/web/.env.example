# Database
DATABASE_URL=postgres://user:password@localhost:5432/amigo

# Valkey (Redis-compatible)
VALKEY_URL=redis://localhost:6379

# Authentik OIDC
# Issuer URL format: https://auth.example.com/application/o/<application-slug>/
AUTHENTIK_ISSUER=https://auth.cadenalabs.net/application/o/amigo/
AUTHENTIK_CLIENT_ID=amigo
AUTHENTIK_CLIENT_SECRET=your-client-secret-here

# App URL (used for OIDC callbacks)
APP_URL=http://localhost:3000

# Web Push VAPID Keys
# Generate with: bunx web-push generate-vapid-keys --json
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@cadenalabs.net
